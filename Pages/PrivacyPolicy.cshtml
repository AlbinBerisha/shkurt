@page "/privacy-policy"
@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container my-5">
    <h1 class="mb-4">Privacy Policy</h1>

    <section class="mb-4">
        <h3>1. Information We Collect</h3>
        <p>We may collect limited technical data necessary to operate the Service, including:</p>
        <ul>
            <li>IP address</li>
            <li>Browser type</li>
            <li>Device information</li>
            <li>Access timestamps</li>
        </ul>
        <p>We do <strong>not</strong> require user accounts and do not collect personal information unless you voluntarily provide it.</p>
    </section>

    <section class="mb-4">
        <h3>2. How We Use Data</h3>
        <ul>
            <li>Operate and maintain the Service</li>
            <li>Ensure security and prevent abuse</li>
            <li>Diagnose technical issues</li>
        </ul>
    </section>

    <section class="mb-4">
        <h3>3. Cookies</h3>
        <p>The Service may use minimal cookies strictly required for basic functionality. No tracking or advertising cookies are used.</p>
    </section>

    <section class="mb-4">
        <h3>4. Data Sharing</h3>
        <p>We do <strong>not</strong> sell, rent, or share your data with third parties.</p>
    </section>

    <section class="mb-4">
        <h3>5. Data Retention</h3>
        <p>We retain data only as long as necessary for maintaining shortened URLs, preventing abuse, or legal obligations.</p>
    </section>

    <section class="mb-4">
        <h3>6. Data Security</h3>
        <p>We implement reasonable security measures, but no system is completely secure.</p>
    </section>

    <section class="mb-4">
        <h3>7. Your Rights</h3>
        <p>You may request deletion of your data by contacting us.</p>
    </section>

    <section>
        <h3>8. Changes to Privacy Policy</h3>
        <p>We may update this policy. Updates will be posted on this page.</p>
    </section>
</div>